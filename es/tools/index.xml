 });

 URCityCombobox.setup('from-city-input', 'from-city', 'from-city-dropdown', SALARY_CITIES);
 URCityCombobox.setup('to-city-input', 'to-city', 'to-city-dropdown', SALARY_CITIES);

 window.calculateSalary = function() {
 var salary = parseFloat(document.getElementById('current-salary').value);
 var fromHidden = document.getElementById('from-city');
 var toHidden = document.getElementById('to-city');
 var fromCity, toCity;

 SALARY_CITIES.forEach(function(c) {
 if (c.value === fromHidden.value) fromCity = c;
 if (c.value === toHidden.value) toCity = c;
 });

 if (!fromCity || !toCity) {
 alert('Please select both cities.');
 return;
 }

 var colFrom = fromCity.col || 100;
 var colTo = toCity.col || 100;
 var nameFrom = fromCity.name;
 var nameTo = toCity.name;

 var neededSalary = Math.round(salary * (colTo / colFrom));
 var diff = salary - neededSalary;
 var pct = Math.round(((neededSalary - salary) / salary) * 100);

 var settings = window.URCitySettings;
 var currencySymbol = settings ? settings.getCurrencySymbol(settings.getState().currency) : '$';

 document.getElementById('from-city-display').textContent = nameFrom;
 document.getElementById('to-city-display').textContent = nameTo;
 document.getElementById('from-salary-display').textContent = currencySymbol + salary.toLocaleString();
 document.getElementById('needed-salary').textContent = currencySymbol + neededSalary.toLocaleString();

 var prefixEl = document.getElementById('salary-prefix');
 if (prefixEl) prefixEl.textContent = currencySymbol;

 var arrowLabel = document.getElementById('salary-change-pct');
 var badge = document.getElementById('salary-badge');

 if (pct &gt; 0) {
 arrowLabel.textContent = '+' + pct + '%';
 arrowLabel.className = 'salary-arrow-label negative';
 badge.textContent = i18n.needMore;
 badge.className = 'result-badge badge-warning';
 } else if (pct &lt; 0) {
 arrowLabel.textContent = pct + '%';
 arrowLabel.className = 'salary-arrow-label positive';
 badge.textContent = i18n.saveMoney;
 badge.className = 'result-badge badge-success';
 } else {
 arrowLabel.textContent = '0%';
 arrowLabel.className = 'salary-arrow-label';
 badge.textContent = i18n.same;
 badge.className = 'result-badge badge-neutral';
 }

 var diffEl = document.getElementById('salary-difference');
 var sym = currencySymbol;
 if (diff &gt; 0) {
 diffEl.innerHTML = '&lt;div class="summary-icon"&gt;🎉&lt;/div&gt;&lt;p&gt;' + i18n.saveMsg.replace('%AMOUNT%', sym + diff.toLocaleString()).replace('%CITY%', nameTo) + '&lt;/p&gt;</description></item></channel></rss>