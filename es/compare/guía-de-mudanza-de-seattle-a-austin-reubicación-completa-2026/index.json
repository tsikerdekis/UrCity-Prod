CITY%. Tu salario actual rinde más ahí.',\n    needMsg: 'Necesitarías \\\\u003cstrong\\\\u003e%AMOUNT%\\/año más\\\\u003c\\/strong\\\\u003e en %CITY% para mantener tu estilo de vida actual.',\n    sameMsg: 'El costo de vida es aproximadamente el mismo. Tu salario tendría poder adquisitivo similar.',\n  };\n  Object.keys(i18n).forEach(function(k) {\n    i18n[k] = i18n[k].replace(/\\\\u003c/g, '\u003c').replace(/\\\\u003e/g, '\u003e');\n  });\n\n  URCityCombobox.setup('from-city-input', 'from-city', 'from-city-dropdown', SALARY_CITIES);\n  URCityCombobox.setup('to-city-input', 'to-city', 'to-city-dropdown', SALARY_CITIES);\n\n  window.calculateSalary = function() {\n    var salary = parseFloat(document.getElementById('current-salary').value);\n    var fromHidden = document.getElementById('from-city');\n    var toHidden = document.getElementById('to-city');\n    var fromCity, toCity;\n\n    SALARY_CITIES.forEach(function(c) {\n      if (c.value === fromHidden.value) fromCity = c;\n      if (c.value === toHidden.value) toCity = c;\n    });\n\n    if (!fromCity || !toCity) {\n      alert('Please select both cities.');\n      return;\n    }\n\n    var colFrom = fromCity.col || 100;\n    var colTo = toCity.col || 100;\n    var nameFrom = fromCity.name;\n    var nameTo = toCity.name;\n\n    var neededSalary = Math.round(salary * (colTo / colFrom));\n    var diff = salary - neededSalary;\n    var pct = Math.round(((neededSalary - salary) / salary) * 100);\n\n    var settings = window.URCitySettings;\n    var currencySymbol = settings ? settings.getCurrencySymbol(settings.getState().currency) : '$';\n\n    document.getElementById('from-city-display').textContent = nameFrom;\n    document.getElementById('to-city-display').textContent = nameTo;\n    document.getElementById('from-salary-display').textContent = currencySymbol + salary.toLocaleString();\n    document.getElementById('needed-salary').textContent = currencySymbol + neededSalary.toLocaleString();\n\n    var prefixEl = document.getElementById('salary-prefix');\n    if (prefixEl) prefixEl.textContent = currencySymbol;\n\n    var arrowLabel = document.getElementById('salary-change-pct');\n    var badge = document.getElementById('salary-badge');\n\n    if (pct \u003e 0) {\n      arrowLabel.textContent = '+' + pct + '%';\n      arrowLabel.className = 'salary-arrow-label negative';\n      badge.textContent = i18n.needMore;\n      badge.className = 'result-badge badge-warning';\n    } else if (pct \u003c 0) {\n      arrowLabel.textContent = pct + '%';\n      arrowLabel.className = 'salary-arrow-label positive';\n      badge.textContent = i18n.saveMoney;\n      badge.className = 'result-badge badge-success';\n    } else {\n      arrowLabel.textContent = '0%';\n      arrowLabel.className = 'salary-arrow-label';\n      badge.textContent = i18n.same;\n      badge.className = 'result-badge badge-neutral';\n    }\n\n    var diffEl = document.getElementById('salary-difference');\n    var sym = currencySymbol;\n    if (diff \u003e 0) {\n      diffEl.innerHTML = '\u003cdiv class=\"summary-icon\"\u003e🎉\u003c/div\u003e\u003cp\u003e' + i18n.saveMsg.replace('%AMOUNT%', sym + diff.toLocaleString()).replace('%CITY%', nameTo) + '\u003c/p\u003e';\n      diffEl.className = 'result-summary positive';\n    } else if (diff \u003c 0) {\n      diffEl.innerHTML = '\u003cdiv class=\"summary-icon\"\u003e📈\u003c/div\u003e\u003cp\u003e' + i18n.needMsg.replace('%AMOUNT%', sym + Math.abs(diff).toLocaleString()).replace('%CITY%', nameTo) + '\u003c/p\u003e';\n      diffEl.className = 'result-summary negative';\n    } else {\n      diffEl.innerHTML = '\u003cdiv class=\"summary-icon\"\u003e⚖️\u003c/div\u003e\u003cp\u003e' + i18n.sameMsg + '\u003c/p\u003e';\n      diffEl.className = 'result-summary';\n    }\n\n    var result = document.getElementById('salary-result');\n    result.style.display = 'block';\n    result.scrollIntoView({ behavior: 'smooth', block: 'nearest' });\n  };\n})();\n\u003c/script\u003e\n\n\u003ch2 id=\"housing-market\"\u003eHousing Market\u003c/h2\u003e\n\u003ch3 id=\"seattle\"\u003eSeattle\u003c/h3\u003e\n\u003cul\u003e\n\u003cli\u003eMedian home: $820,000\u003c/li\u003e\n\u003cli\u003eMedian rent (1BR): $2,350/month\u003c/li\u003e\n\u003cli\u003ePrice per sq ft: $520\u003c/li\u003e\n\u003c/ul\u003e\n\u003ch3 id=\"austin\"\u003eAustin\u003c/h3\u003e\n\u003cul\u003e\n\u003cli\u003eMedian home: $450,000\u003c/li\u003e\n\u003cli\u003eMedian rent (1BR): $1,650/month\u003c/li\u003e\n\u003cli\u003ePrice per sq ft: $285\u003c/li\u003e\n\u003c/ul\u003e\n\u003cp\u003e\u003cstrong\u003eAustin housing is 45% cheaper than Seattle.\u003c/strong\u003e\u003c/p\u003e\n\u003ch2 id=\"taxes\"\u003eTaxes\u003c/h2\u003e\n\u003ctable\u003e\n\t\u003cthead\u003e\n\t\t\t\u003ctr\u003e\n\t\t\t\t\t\u003cth\u003eTax Type\u003c/th\u003e\n\t\t\t\t\t\u003cth\u003eSeattle\u003c/th\u003e\n\t\t\t\t\t\u003cth\u003eAustin\u003c/th\u003e\n\t\t\t\u003c/tr\u003e\n\t\u003c/thead\u003e\n\t\u003ctbody\u003e\n\t\t\t\u003ctr\u003e\n\t\t\t\t\t\u003ctd\u003eState Income Tax\u003c/td\u003e\n\t\t\t\t\t\u003ctd\u003e0%\u003c/td\u003e\n\t\t\t\t\t\u003ctd\u003e\u003cstrong\u003e0%\u003c/strong\u003e\u003c/td\u003e\n\t\t\t\u003c/tr\u003e\n\t\t\t\u003ctr\u003e\n\t\t\t\t\t\u003ctd\u003eCity Income Tax\u003c/td\u003e\n\t\t\t\t\t\u003ctd\u003e0%\u003c/td\u003e\n\t\t\t\t\t\u003ctd\u003e\u003cstrong\u003e0%\u003c/strong\u003e\u003c/td\u003e\n\t\t\t\u003c/tr\u003e\n\t\t\t\u003ctr\u003e\n\t\t\t\t\t\u003ctd\u003eSales Tax\u003c/td\u003e\n\t\t\t\t\t\u003ctd\u003e10.25%\u003c/td\u003e\n\t\t\t\t\t\u003ctd\u003e8.25%\u003c/td\u003e\n\t\t\t\u003c/tr\u003e\n\t\t\t\u003ctr\u003e\n\t\t\t\t\t\u003ctd\u003eProperty Tax\u003c/td\u003e\n\t\t\t\t\t\u003ctd\u003e~0.93%\u003c/td\u003e\n\t\t\t\t\t\u003ctd\u003e~1.8%\u003c/td\u003e\n\t\t\t\u003c/tr\u003e\n\t\u003c/tbody\u003e\n\u003c/table\u003e\n\u003cp\u003e\u003cstrong\u003eBoth cities have no state income tax — a major advantage.\u003c/strong\u003e\u003c/p\u003e\n\u003ch2 id=\"climate\"\u003eClimate\u003c/h2\u003e\n\u003ctable\u003e\n\t\u003cthead\u003e\n\t\t\t\u003ctr\u003e\n\t\t\t\t\t\u003cth\u003e\u003c/th\u003e\n\t\t\t\t\t\u003cth\u003eSeattle\u003c/th\u003e\n\t\t\t\t\t\u003cth\u003eAustin\u003c/th\u003e\n\t\t\t\u003c/tr\u003e\n\t\u003c/thead\u003e\n\t\u003ctbody\u003e\n\t\t\t\u003ctr\u003e\n\t\t\t\t\t\u003ctd\u003eSummer High\u003c/td\u003e\n\t\t\t\t\t\u003ctd\u003e76°F\u003c/td\u003e\n\t\t\t\t\t\u003ctd\u003e96°F\u003c/td\u003e\n\t\t\t\u003c/tr\u003e\n\t\t\t\u003ctr\u003e\n\t\t\t\t\t\u003ctd\u003eWinter Low\u003c/td\u003e\n\t\t\t\t\t\u003ctd\u003e37°F\u003c/td\u003e\n\t\t\t\t\t\u003ctd\u003e41°F\u003c/td\u003e\n\t\t\t\u003c/tr\u003e\n\t\t\t\u003ctr\u003e\n\t\t\t\t\t\u003ctd\u003eSunny Days\u003c/td\u003e\n\t\t\t\t\t\u003ctd\u003e152\u003c/td\u003e\n\t\t\t\t\t\u003ctd\u003e228\u003c/td\u003e\n\t\t\t\u003c/tr\u003e\n\t\t\t\u003ctr\u003e\n\t\t\t\t\t\u003ctd\u003eRainfall\u003c/td\u003e\n\t\t\t\t\t\u003ctd\u003e37\u0026quot;\u003c/td\u003e\n\t\t\t\t\t\u003ctd\u003e35\u0026quot;\u003c/td\u003e\n\t\t\t\u003c/tr\u003e\n\t\u003c/tbody\u003e\n\u003c/table\u003e\n\u003cp\u003e\u003cstrong\u003eTrade-off:\u003c/strong\u003e Austin is much sunnier and hotter. Seattle has milder summers but gray winters.\u003c/p\u003e\n\u003ch2 id=\"culture--lifestyle\"\u003eCulture \u0026amp; Lifestyle\u003c/h2\u003e\n\u003ch3 id=\"what-youll-miss-from-seattle\"\u003eWhat You\u0026rsquo;ll Miss from Seattle\u003c/h3\u003e\n\u003cul\u003e\n\u003cli\u003eMountains and hiking (Rainier, Cascades)\u003c/li\u003e\n\u003cli\u003eCoffee culture\u003c/li\u003e\n\u003cli\u003eMild summer weather\u003c/li\u003e\n\u003cli\u003eProgressive politics\u003c/li\u003e\n\u003cli\u003eWater access (Puget Sound, lakes)\u003c/li\u003e\n\u003c/ul\u003e\n\u003ch3 id=\"what-youll-gain-in-austin\"\u003eWhat You\u0026rsquo;ll Gain in Austin\u003c/h3\u003e\n\u003cul\u003e\n\u003cli\u003e228 sunny days per year\u003c/li\u003e\n\u003cli\u003eLive music capital of the world\u003c/li\u003e\n\u003cli\u003eBBQ and Tex-Mex\u003c/li\u003e\n\u003cli\u003eMore affordable everything\u003c/li\u003e\n\u003cli\u003eNo state income tax\u003c/li\u003e\n\u003c/ul\u003e\n\u003ch2 id=\"best-neighborhoods-in-austin-for-seattle-transplants\"\u003eBest Neighborhoods in Austin for Seattle Transplants\u003c/h2\u003e\n\u003col\u003e\n\u003cli\u003e\u003cstrong\u003eEast Austin\u003c/strong\u003e — Trendy, artsy, most like Capitol Hill\u003c/li\u003e\n\u003cli\u003e\u003cstrong\u003eSouth Congress\u003c/strong\u003e — Walkable shops and restaurants\u003c/li\u003e\n\u003cli\u003e\u003cstrong\u003eMueller\u003c/strong\u003e — Planned community with parks\u003c/li\u003e\n\u003cli\u003e\u003cstrong\u003eDowntown Austin\u003c/strong\u003e — Urban, like South Lake Union\u003c/li\u003e\n\u003c/ol\u003e\n\u003ch2 id=\"is-it-worth-it\"\u003eIs It Worth It?\u003c/h2\u003e\n\u003cp\u003e\u003cstrong\u003eYes — if you prefer sun to rain.\u003c/strong\u003e\u003c/p\u003e\n\u003cp\u003eBoth cities have no state income tax and strong tech economies. Austin is significantly cheaper (31% lower cost of living) and much sunnier. The main trade-offs are summer heat and less outdoor scenery.\u003c/p\u003e\n\u003chr\u003e\n\u003ch2 id=\"frequently-asked-questions\"\u003eFrequently Asked Questions\u003c/h2\u003e\n\u003ch3 id=\"will-my-salary-go-down\"\u003eWill my salary go down?\u003c/h3\u003e\n\u003cp\u003e\u003cstrong\u003ePossibly.\u003c/strong\u003e Tech salaries in Austin are typically 10–20% lower than Seattle. However, the cost savings more than offset the difference.\u003c/p\u003e\n\u003ch3 id=\"is-austins-tech-scene-as-good-as-seattles\"\u003eIs Austin\u0026rsquo;s tech scene as good as Seattle\u0026rsquo;s?\u003c/h3\u003e\n\u003cp\u003e\u003cstrong\u003eDifferent but robust.\u003c/strong\u003e Seattle has Microsoft and Amazon headquarters. Austin has Apple, Google, Meta, Tesla, Dell, and thousands of startups.\u003c/p\u003e\n\u003ch3 id=\"whats-the-biggest-culture-shock\"\u003eWhat\u0026rsquo;s the biggest culture shock?\u003c/h3\u003e\n\u003cp\u003e\u003cstrong\u003eThe heat and the driving.\u003c/strong\u003e Austin summers are extreme (100°F+). And unlike Seattle\u0026rsquo;s decent public transit, Austin is car-dependent.\u003c/p\u003e\n\u003ch3 id=\"hows-the-outdoor-scene\"\u003eHow\u0026rsquo;s the outdoor scene?\u003c/h3\u003e\n\u003cp\u003e\u003cstrong\u003eGood but different.\u003c/strong\u003e Austin has Lady Bird Lake, Barton Springs, and Hill Country hiking. But it\u0026rsquo;s not the Pacific Northwest.\u003c/p\u003e\n\u003ch2 id=\"data-sources\"\u003eData Sources\u003c/h2\u003e\n\u003cul\u003e\n\u003cli\u003eCost of living: Council for Community and Economic Research (C2ER)\u003c/li\u003e\n\u003cli\u003eHousing data: Zillow Research\u003c/li\u003e\n\u003cli\u003eTax data: Tax Foundation\u003c/li\u003e\n\u003cli\u003eMigration data: IRS Statistics of Income\u003c/li\u003e\n\u003c/ul\u003e\n\u003cp\u003e\u003cem\u003eLast updated: June 28, 2026\u003c/em\u003e\u003c/p\u003e\n"}