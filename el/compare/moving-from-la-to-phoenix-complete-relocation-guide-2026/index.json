ITY% για να διατηρήσετε το σημερινό σας βιοτικό επίπεδο.',\n    sameMsg: 'Το κόστος ζωής είναι περίπου το ίδιο. Ο μισθός σας θα έχει παρόμοια αγοραστική δύναμη.',\n  };\n  Object.keys(i18n).forEach(function(k) {\n    i18n[k] = i18n[k].replace(/\\\\u003c/g, '\u003c').replace(/\\\\u003e/g, '\u003e');\n  });\n\n  URCityCombobox.setup('from-city-input', 'from-city', 'from-city-dropdown', SALARY_CITIES);\n  URCityCombobox.setup('to-city-input', 'to-city', 'to-city-dropdown', SALARY_CITIES);\n\n  window.calculateSalary = function() {\n    var salary = parseFloat(document.getElementById('current-salary').value);\n    var fromHidden = document.getElementById('from-city');\n    var toHidden = document.getElementById('to-city');\n    var fromCity, toCity;\n\n    SALARY_CITIES.forEach(function(c) {\n      if (c.value === fromHidden.value) fromCity = c;\n      if (c.value === toHidden.value) toCity = c;\n    });\n\n    if (!fromCity || !toCity) {\n      alert('Please select both cities.');\n      return;\n    }\n\n    var colFrom = fromCity.col || 100;\n    var colTo = toCity.col || 100;\n    var nameFrom = fromCity.name;\n    var nameTo = toCity.name;\n\n    var neededSalary = Math.round(salary * (colTo / colFrom));\n    var diff = salary - neededSalary;\n    var pct = Math.round(((neededSalary - salary) / salary) * 100);\n\n    var settings = window.URCitySettings;\n    var currencySymbol = settings ? settings.getCurrencySymbol(settings.getState().currency) : '$';\n\n    document.getElementById('from-city-display').textContent = nameFrom;\n    document.getElementById('to-city-display').textContent = nameTo;\n    document.getElementById('from-salary-display').textContent = currencySymbol + salary.toLocaleString();\n    document.getElementById('needed-salary').textContent = currencySymbol + neededSalary.toLocaleString();\n\n    var prefixEl = document.getElementById('salary-prefix');\n    if (prefixEl) prefixEl.textContent = currencySymbol;\n\n    var arrowLabel = document.getElementById('salary-change-pct');\n    var badge = document.getElementById('salary-badge');\n\n    if (pct \u003e 0) {\n      arrowLabel.textContent = '+' + pct + '%';\n      arrowLabel.className = 'salary-arrow-label negative';\n      badge.textContent = i18n.needMore;\n      badge.className = 'result-badge badge-warning';\n    } else if (pct \u003c 0) {\n      arrowLabel.textContent = pct + '%';\n      arrowLabel.className = 'salary-arrow-label positive';\n      badge.textContent = i18n.saveMoney;\n      badge.className = 'result-badge badge-success';\n    } else {\n      arrowLabel.textContent = '0%';\n      arrowLabel.className = 'salary-arrow-label';\n      badge.textContent = i18n.same;\n      badge.className = 'result-badge badge-neutral';\n    }\n\n    var diffEl = document.getElementById('salary-difference');\n    var sym = currencySymbol;\n    if (diff \u003e 0) {\n      diffEl.innerHTML = '\u003cdiv class=\"summary-icon\"\u003e🎉\u003c/div\u003e\u003cp\u003e' + i18n.saveMsg.replace('%AMOUNT%', sym + diff.toLocaleString()).replace('%CITY%', nameTo) + '\u003c/p\u003e';\n      diffEl.className = 'result-summary positive';\n    } else if (diff \u003c 0) {\n      diffEl.innerHTML = '\u003cdiv class=\"summary-icon\"\u003e📈\u003c/div\u003e\u003cp\u003e' + i18n.needMsg.replace('%AMOUNT%', sym + Math.abs(diff).toLocaleString()).replace('%CITY%', nameTo) + '\u003c/p\u003e';\n      diffEl.className = 'result-summary negative';\n    } else {\n      diffEl.innerHTML = '\u003cdiv class=\"summary-icon\"\u003e⚖️\u003c/div\u003e\u003cp\u003e' + i18n.sameMsg + '\u003c/p\u003e';\n      diffEl.className = 'result-summary';\n    }\n\n    var result = document.getElementById('salary-result');\n    result.style.display = 'block';\n    result.scrollIntoView({ behavior: 'smooth', block: 'nearest' });\n  };\n})();\n\u003c/script\u003e\n\n\u003ch2 id=\"housing-market\"\u003eHousing Market\u003c/h2\u003e\n\u003ch3 id=\"los-angeles\"\u003eLos Angeles\u003c/h3\u003e\n\u003cul\u003e\n\u003cli\u003eMedian home: $850,000\u003c/li\u003e\n\u003cli\u003eMedian rent (1BR): $2,800/month\u003c/li\u003e\n\u003cli\u003ePrice per sq ft: $650\u003c/li\u003e\n\u003c/ul\u003e\n\u003ch3 id=\"phoenix\"\u003ePhoenix\u003c/h3\u003e\n\u003cul\u003e\n\u003cli\u003eMedian home: $420,000\u003c/li\u003e\n\u003cli\u003eMedian rent (1BR): $1,450/month\u003c/li\u003e\n\u003cli\u003ePrice per sq ft: $245\u003c/li\u003e\n\u003c/ul\u003e\n\u003cp\u003e\u003cstrong\u003eYou can buy a 3-bedroom house in Phoenix for half the price of a 1-bedroom condo in LA.\u003c/strong\u003e\u003c/p\u003e\n\u003ch2 id=\"taxes\"\u003eTaxes\u003c/h2\u003e\n\u003ctable\u003e\n\t\u003cthead\u003e\n\t\t\t\u003ctr\u003e\n\t\t\t\t\t\u003cth\u003eTax Type\u003c/th\u003e\n\t\t\t\t\t\u003cth\u003eLos Angeles\u003c/th\u003e\n\t\t\t\t\t\u003cth\u003ePhoenix\u003c/th\u003e\n\t\t\t\u003c/tr\u003e\n\t\u003c/thead\u003e\n\t\u003ctbody\u003e\n\t\t\t\u003ctr\u003e\n\t\t\t\t\t\u003ctd\u003eState Income Tax\u003c/td\u003e\n\t\t\t\t\t\u003ctd\u003e9.3%\u003c/td\u003e\n\t\t\t\t\t\u003ctd\u003e2.59%\u003c/td\u003e\n\t\t\t\u003c/tr\u003e\n\t\t\t\u003ctr\u003e\n\t\t\t\t\t\u003ctd\u003eCity Income Tax\u003c/td\u003e\n\t\t\t\t\t\u003ctd\u003e0%\u003c/td\u003e\n\t\t\t\t\t\u003ctd\u003e0%\u003c/td\u003e\n\t\t\t\u003c/tr\u003e\n\t\t\t\u003ctr\u003e\n\t\t\t\t\t\u003ctd\u003eSales Tax\u003c/td\u003e\n\t\t\t\t\t\u003ctd\u003e9.5%\u003c/td\u003e\n\t\t\t\t\t\u003ctd\u003e8.6%\u003c/td\u003e\n\t\t\t\u003c/tr\u003e\n\t\t\t\u003ctr\u003e\n\t\t\t\t\t\u003ctd\u003eProperty Tax\u003c/td\u003e\n\t\t\t\t\t\u003ctd\u003e~0.82%\u003c/td\u003e\n\t\t\t\t\t\u003ctd\u003e~0.62%\u003c/td\u003e\n\t\t\t\u003c/tr\u003e\n\t\u003c/tbody\u003e\n\u003c/table\u003e\n\u003cp\u003e\u003cstrong\u003eAnnual tax savings on $80K salary: ~$5,400\u003c/strong\u003e\u003c/p\u003e\n\u003ch2 id=\"climate\"\u003eClimate\u003c/h2\u003e\n\u003ctable\u003e\n\t\u003cthead\u003e\n\t\t\t\u003ctr\u003e\n\t\t\t\t\t\u003cth\u003e\u003c/th\u003e\n\t\t\t\t\t\u003cth\u003eLos Angeles\u003c/th\u003e\n\t\t\t\t\t\u003cth\u003ePhoenix\u003c/th\u003e\n\t\t\t\u003c/tr\u003e\n\t\u003c/thead\u003e\n\t\u003ctbody\u003e\n\t\t\t\u003ctr\u003e\n\t\t\t\t\t\u003ctd\u003eSummer High\u003c/td\u003e\n\t\t\t\t\t\u003ctd\u003e84°F\u003c/td\u003e\n\t\t\t\t\t\u003ctd\u003e106°F\u003c/td\u003e\n\t\t\t\u003c/tr\u003e\n\t\t\t\u003ctr\u003e\n\t\t\t\t\t\u003ctd\u003eWinter Low\u003c/td\u003e\n\t\t\t\t\t\u003ctd\u003e48°F\u003c/td\u003e\n\t\t\t\t\t\u003ctd\u003e46°F\u003c/td\u003e\n\t\t\t\u003c/tr\u003e\n\t\t\t\u003ctr\u003e\n\t\t\t\t\t\u003ctd\u003eSunny Days\u003c/td\u003e\n\t\t\t\t\t\u003ctd\u003e284\u003c/td\u003e\n\t\t\t\t\t\u003ctd\u003e299\u003c/td\u003e\n\t\t\t\u003c/tr\u003e\n\t\t\t\u003ctr\u003e\n\t\t\t\t\t\u003ctd\u003eHumidity\u003c/td\u003e\n\t\t\t\t\t\u003ctd\u003eLow\u003c/td\u003e\n\t\t\t\t\t\u003ctd\u003eVery Low\u003c/td\u003e\n\t\t\t\u003c/tr\u003e\n\t\u003c/tbody\u003e\n\u003c/table\u003e\n\u003cp\u003e\u003cstrong\u003eTrade-off:\u003c/strong\u003e Phoenix summers are extreme (105°F+), but winters are mild and everything is air-conditioned.\u003c/p\u003e\n\u003ch2 id=\"culture--lifestyle\"\u003eCulture \u0026amp; Lifestyle\u003c/h2\u003e\n\u003ch3 id=\"what-youll-miss-from-la\"\u003eWhat You\u0026rsquo;ll Miss from LA\u003c/h3\u003e\n\u003cul\u003e\n\u003cli\u003eBeaches and ocean\u003c/li\u003e\n\u003cli\u003eHollywood and entertainment industry\u003c/li\u003e\n\u003cli\u003eDiverse food scene\u003c/li\u003e\n\u003cli\u003eMountains and hiking\u003c/li\u003e\n\u003cli\u003eCooler summer temperatures\u003c/li\u003e\n\u003c/ul\u003e\n\u003ch3 id=\"what-youll-gain-in-phoenix\"\u003eWhat You\u0026rsquo;ll Gain in Phoenix\u003c/h3\u003e\n\u003cul\u003e\n\u003cli\u003eMuch lower cost of living\u003c/li\u003e\n\u003cli\u003eSimilar desert landscapes\u003c/li\u003e\n\u003cli\u003eGolf and outdoor recreation\u003c/li\u003e\n\u003cli\u003eLess traffic\u003c/li\u003e\n\u003cli\u003eStrong job market\u003c/li\u003e\n\u003c/ul\u003e\n\u003ch2 id=\"best-neighborhoods-in-phoenix-for-la-transplants\"\u003eBest Neighborhoods in Phoenix for LA Transplants\u003c/h2\u003e\n\u003col\u003e\n\u003cli\u003e\u003cstrong\u003eScottsdale\u003c/strong\u003e — Upscale, like Beverly Hills\u003c/li\u003e\n\u003cli\u003e\u003cstrong\u003eArcadia\u003c/strong\u003e — Leafy and affluent, like Pasadena\u003c/li\u003e\n\u003cli\u003e\u003cstrong\u003eDowntown Phoenix\u003c/strong\u003e — Urban, like DTLA\u003c/li\u003e\n\u003cli\u003e\u003cstrong\u003eTempe\u003c/strong\u003e — Young and energetic, like Santa Monica\u003c/li\u003e\n\u003c/ol\u003e\n\u003ch2 id=\"is-it-worth-it\"\u003eIs It Worth It?\u003c/h2\u003e\n\u003cp\u003e\u003cstrong\u003eYes — if you can handle 110°F summers.\u003c/strong\u003e\u003c/p\u003e\n\u003cp\u003eThe financial case is clear: you\u0026rsquo;ll save $25,000+ annually on housing and taxes. Phoenix has a strong economy and growing tech sector. The main trade-off is extreme summer heat and no ocean access.\u003c/p\u003e\n\u003chr\u003e\n\u003ch2 id=\"frequently-asked-questions\"\u003eFrequently Asked Questions\u003c/h2\u003e\n\u003ch3 id=\"is-phoenix-too-hot\"\u003eIs Phoenix too hot?\u003c/h3\u003e\n\u003cp\u003eSummers are extreme (105°F+), but everything is air-conditioned. Many residents love the 8-month \u0026ldquo;perfect season\u0026rdquo; from October to May.\u003c/p\u003e\n\u003ch3 id=\"will-my-salary-go-down\"\u003eWill my salary go down?\u003c/h3\u003e\n\u003cp\u003e\u003cstrong\u003ePossibly.\u003c/strong\u003e Salaries in Phoenix are typically 10–15% lower than LA. However, the cost savings more than offset the difference.\u003c/p\u003e\n\u003ch3 id=\"is-there-anything-to-do\"\u003eIs there anything to do?\u003c/h3\u003e\n\u003cp\u003e\u003cstrong\u003eYes.\u003c/strong\u003e Phoenix has professional sports (Suns, Cardinals, Diamondbacks), hiking (Camelback Mountain), golf, and a growing food scene.\u003c/p\u003e\n\u003ch3 id=\"hows-the-water-situation\"\u003eHow\u0026rsquo;s the water situation?\u003c/h3\u003e\n\u003cp\u003ePhoenix has secured water supplies through 2085, but conservation is increasingly important.\u003c/p\u003e\n\u003ch2 id=\"data-sources\"\u003eData Sources\u003c/h2\u003e\n\u003cul\u003e\n\u003cli\u003eCost of living: Council for Community and Economic Research (C2ER)\u003c/li\u003e\n\u003cli\u003eHousing data: Zillow Research\u003c/li\u003e\n\u003cli\u003eTax data: Tax Foundation\u003c/li\u003e\n\u003cli\u003eMigration data: IRS Statistics of Income\u003c/li\u003e\n\u003c/ul\u003e\n\u003cp\u003e\u003cem\u003eLast updated: June 28, 2026\u003c/em\u003e\u003c/p\u003e\n"}