{"title":"Calculateur de propriété","description":"Calculez le vrai coût de la possession d'une maison — hypothèque, taxes, assurance, HOA et entretien sur 30 ans.","url":"https://urcity.com/fr/tools/home-ownership-calculator/","content":"\u003ch2 id=\"calculateur-de-propriété\"\u003eCalculateur de propriété\u003c/h2\u003e\n\u003cp\u003eAcheter une maison, c\u0026rsquo;est bien plus qu\u0026rsquo;un simple paiement hypothécaire. Voyez l\u0026rsquo;image complète avec notre calculateur du vrai coût de la propriété.\u003c/p\u003e\n\u003cdiv class=\"calculator-widget\" id=\"home-calc\"\u003e\n    \u003cdiv class=\"calc-header\"\u003e\n        \u003cdiv class=\"calc-icon green\"\u003e\n            \u003csvg\n                width=\"28\"\n                height=\"28\"\n                viewBox=\"0 0 24 24\"\n                fill=\"none\"\n                stroke=\"currentColor\"\n                stroke-width=\"2\"\n            \u003e\n                \u003cpath d=\"M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z\" /\u003e\n                \u003cpolyline points=\"9 22 9 12 15 12 15 22\" /\u003e\n            \u003c/svg\u003e\n        \u003c/div\u003e\n        \u003cdiv class=\"calc-title-group\"\u003e\n            \u003ch3\u003eVrai coût de la propriété\u003c/h3\u003e\n            \u003cp class=\"calc-subtitle\"\u003e\n                Voyez ce que vous paierez vraiment sur 30 ans\n            \u003c/p\u003e\n        \u003c/div\u003e\n    \u003c/div\u003e\n\n                                \n\n    \u003cdiv class=\"calc-inputs-row three-col\"\u003e\n        \u003cdiv class=\"calc-field\"\u003e\n            \u003clabel for=\"home-price\"\u003e\n                \u003csvg\n                    width=\"16\"\n                    height=\"16\"\n                    viewBox=\"0 0 24 24\"\n                    fill=\"none\"\n                    stroke=\"currentColor\"\n                    stroke-width=\"2\"\n                \u003e\n                    \u003cline x1=\"12\" y1=\"1\" x2=\"12\" y2=\"23\" /\u003e\n                    \u003cpath\n                        d=\"M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6\"\n                    /\u003e\n                \u003c/svg\u003e\n                Prix du logement\n            \u003c/label\u003e\n            \u003cdiv class=\"input-prefix\"\u003e\n                \u003cspan class=\"prefix\"\u003e$\u003c/span\u003e\n                \u003cinput\n                    type=\"number\"\n                    id=\"home-price\"\n                    value=\"450000\"\n                    min=\"0\"\n                    step=\"10000\"\n                /\u003e\n            \u003c/div\u003e\n        \u003c/div\u003e\n\n        \u003cdiv class=\"calc-field\"\u003e\n            \u003clabel for=\"down-payment\"\u003e\n                \u003csvg\n                    width=\"16\"\n                    height=\"16\"\n                    viewBox=\"0 0 24 24\"\n                    fill=\"none\"\n                    stroke=\"currentColor\"\n                    stroke-width=\"2\"\n                \u003e\n                    \u003cpolyline points=\"23 6 13.5 15.5 8.5 10.5 1 18\" /\u003e\n                    \u003cpolyline points=\"17 6 23 6 23 12\" /\u003e\n                \u003c/svg\u003e\n                Apport initial\n            \u003c/label\u003e\n            \u003cdiv class=\"input-suffix\"\u003e\n                \u003cinput\n                    type=\"number\"\n                    id=\"down-payment\"\n                    value=\"20\"\n                    min=\"0\"\n                    max=\"100\"\n                    step=\"5\"\n                /\u003e\n                \u003cspan class=\"suffix\"\u003e%\u003c/span\u003e\n            \u003c/div\u003e\n            \u003cdiv class=\"field-hint\" id=\"down-payment-hint\"\u003e\n                $90,000 d\u0026#39;apport\n            \u003c/div\u003e\n        \u003c/div\u003e\n\n        \u003cdiv class=\"calc-field\"\u003e\n            \u003clabel for=\"interest-rate\"\u003e\