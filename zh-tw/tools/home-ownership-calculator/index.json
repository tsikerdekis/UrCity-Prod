03e\u003c/span\u003e\n                        電費\n                    \u003c/div\u003e\n                    \u003cdiv class=\"breakdown-bar-track\"\u003e\n                        \u003cdiv\n                            class=\"breakdown-bar\"\n                            id=\"bar-mo-elec\"\n                            style=\"background: #f97316\"\n                        \u003e\u003c/div\u003e\n                    \u003c/div\u003e\n                    \u003cdiv class=\"breakdown-value\" id=\"val-mo-elec\"\u003e$0\u003c/div\u003e\n                \u003c/div\u003e\n                \u003cdiv class=\"breakdown-row\"\u003e\n                    \u003cdiv class=\"breakdown-label\"\u003e\n                        \u003cspan\n                            class=\"breakdown-dot\"\n                            style=\"background: #06b6d4\"\n                        \u003e\u003c/span\u003e\n                        水費\n                    \u003c/div\u003e\n                    \u003cdiv class=\"breakdown-bar-track\"\u003e\n                        \u003cdiv\n                            class=\"breakdown-bar\"\n                            id=\"bar-mo-water\"\n                            style=\"background: #06b6d4\"\n                        \u003e\u003c/div\u003e\n                    \u003c/div\u003e\n                    \u003cdiv class=\"breakdown-value\" id=\"val-mo-water\"\u003e$0\u003c/div\u003e\n                \u003c/div\u003e\n                \u003cdiv class=\"breakdown-row\"\u003e\n                    \u003cdiv class=\"breakdown-label\"\u003e\n                        \u003cspan\n                            class=\"breakdown-dot\"\n                            style=\"background: #84cc16\"\n                        \u003e\u003c/span\u003e\n                        網絡費\n                    \u003c/div\u003e\n                    \u003cdiv class=\"breakdown-bar-track\"\u003e\n                        \u003cdiv\n                            class=\"breakdown-bar\"\n                            id=\"bar-mo-net\"\n                            style=\"background: #84cc16\"\n                        \u003e\u003c/div\u003e\n                    \u003c/div\u003e\n                    \u003cdiv class=\"breakdown-value\" id=\"val-mo-net\"\u003e$0\u003c/div\u003e\n                \u003c/div\u003e\n                \u003cdiv class=\"breakdown-row\"\u003e\n                    \u003cdiv class=\"breakdown-label\"\u003e\n                        \u003cspan\n                            class=\"breakdown-dot\"\n                            style=\"background: #a855f7\"\n                        \u003e\u003c/span\u003e\n                        垃圾處理費\n                    \u003c/div\u003e\n                    \u003cdiv class=\"breakdown-bar-track\"\u003e\n                        \u003cdiv\n                            class=\"breakdown-bar\"\n                            id=\"bar-mo-trash\"\n                            style=\"background: #a855f7\"\n                        \u003e\u003c/div\u003e\n                    \u003c/div\u003e\n                    \u003cdiv class=\"breakdown-value\" id=\"val-mo-trash\"\u003e$0\u003c/div\u003e\n                \u003c/div\u003e\n                \u003cdiv class=\"breakdown-row\"\u003e\n                    \u003cdiv class=\"breakdown-label\"\u003e\n                        \u003cspan\n                            class=\"breakdown-dot\"\n                            style=\"background: #ef4444\"\n                        \u003e\u003c/span\u003e\n                        供暖\n                    \u003c/div\u003e\n                    \u003cdiv class=\"breakdown-bar-track\"\u003e\n                        \u003cdiv\n                            class=\"breakdown-bar\"\n                            id=\"bar-mo-heating\"\n                            style=\"background: #ef4444\"\n                        \u003e\u003c/div\u003e\n                    \u003c/div\u003e\n                    \u003cdiv class=\"breakdown-value\" id=\"val-mo-heating\"\u003e$0\u003c/div\u003e\n                \u003c/div\u003e\n                \u003cdiv class=\"breakdown-row\"\u003e\n                    \u003cdiv class=\"breakdown-label\"\u003e\n                        \u003cspan\n                            class=\"breakdown-dot\"\n                            style=\"background: #3b82f6\"\n                        \u003e\u003c/span\u003e\n                        製冷（空調）\n                    \u003c/div\u003e\n                    \u003cdiv class=\"breakdown-bar-track\"\u003e\n                        \u003cdiv\n                            class=\"breakdown-bar\"\n                            id=\"bar-mo-cooling\"\n                            style=\"background: #3b82f6\"\n                        \u003e\u003c/div\u003e\n                    \u003c/div\u003e\n                    \u003cdiv class=\"breakdown-value\" id=\"val-mo-cooling\"\u003e$0\u003c/div\u003e\n                \u003c/div\u003e\n            \u003c/div\u003e\n\n            \u003cdiv class=\"result-summary\" id=\"monthly-insight\"\u003e\u003c/div\u003e\n        \u003c/div\u003e\n    \u003c/div\u003e\n\u003c/div\u003e\n\n\u003cscript\u003e\n    const homeCalcI18n = {\n        downSuffix: '首付',\n        included: 'Included',\n        insight30yr: '一套\\u003cstrong\\u003e%PRICE%\\u003c\\/strong\\u003e的房屋在30年內實際花費\\u003cstrong\\u003e%TOTAL%\\u003c\\/strong\\u003e。計入利息、稅費、保險和費用後，這比標價高出\\u003cstrong\\u003e%PCT%\\u003c\\/strong\\u003e。',\n        insightMonthly: '水電費在房屋擁有成本之上每月增加\\u003cstrong\\u003e%UTILS%\\u003c\\/strong\\u003e。它們佔您月住房總支出的\\u003cstrong\\u003e%PCT%\\u003c\\/strong\\u003e。',\n    };\n    const homePriceInput = document.getElementById(\"home-price\");\n    const downPaymentInput = document.getElementById(\"down-payment\");\n    function updateDownHint() {\n        const price = parseFloat(homePriceInput.value) || 0;\n        const pct = parseFloat(downPaymentInput.value) || 0;\n        const amount = Math.round(price * (pct / 100));\n        const settings = window.URCitySettings;\n        const sym = settings\n            ? settings.getCurrencySymbol(settings.getState().currency)\n            : \"$\";\n        document.getElementById(\"down-payment-hint\").textContent =\n            sym + amount.toLocaleString() + \" \" + homeCalcI18n.downSuffix;\n    }\n    homePriceInput.addEventListener(\"input\", updateDownHint);\n    downPaymentInput.addEventListener(\"input\", updateDownHint);\n    updateDownHint();\n\n    document.addEventListener(\"urcity-settings-change\", function () {\n        const settings = window.URCitySettings;\n        if (!settings || !settings.getState) return;\n        const sym = settings.getCurrencySymbol(settings.getState().currency);\n        document\n            .querySelectorAll(\"#home-calc .input-prefix .prefix\")\n            .forEach(function (el) {\n                el.textContent = sym;\n            });\n    });\n\n    function switchTab(tabId) {\n        \n        document\n            .querySelectorAll(\".calc-tab\")\n            .forEach((btn) =\u003e btn.classList.remove(\"active\"));\n        document\n            .getElementById(\"tab-btn-\" + tabId.replace(\"tab-\", \"\"))\n            .classList.add(\"active\");\n        \n        document\n            .querySelectorAll(\".calc-tab-panel\")\n            .forEach((panel) =\u003e panel.classList.remove(\"active\"));\n        document.getElementById(tabId).classList.add(\"active\");\n    }\n\n    function calculateHome() {\n        const price = parseFloat(document.getElementById(\"home-price\").value);\n        const downPercent = parseFloat(\n            document.getElementById(\"down-payment\").value,\n        );\n        const rate = parseFloat(document.getElementById(\"interest-rate\").value);\n        const taxRate = parseFloat(document.getElementById(\"tax-rate\").value);\n        const hoa = parseFloat(document.getElementById(\"hoa\").value);\n\n        const settings = window.URCitySettings;\n        const displayCurrency = settings\n            ? settings.getState().currency\n            : \"USD\";\n        const sym = settings\n            ? settings.getCurrencySymbol(displayCurrency)\n            : \"$\";\n\n        \n        const nativeCurrency = document.getElementById(\"calc-currency\")\n            ? document.getElementById(\"calc-currency\").value\n            : \"USD\";\n        const nativeSym = settings\n            ? settings.getCurrencySymbol(nativeCurrency)\n            : \"$\";\n\n        \n        function toDisplay(val) {\n            if (!settings || displayCurrency === nativeCurrency) return val;\n            return settings.convertAmount(val, nativeCurrency, displayCurrency);\n        }\n\n        \n        const utilElec =\n            parseFloat(document.getElementById(\"util-elec\").value) || 0;\n        const utilWater =\n            parseFloat(document.getElementById(\"util-water\").value) || 0;\n        const utilNet =\n            parseFloat(document.getElementById(\"util-net\").value) || 0;\n        const utilTrash =\n            parseFloat(document.getElementById(\"util-trash\").value) || 0;\n        const utilHeating =\n            parseFloat(document.getElementById(\"util-heating\").value) || 0;\n        const utilCooling =\n            parseFloat(document.getElementById(\"util-cooling\").value) || 0;\n        const totalUtilities =\n            utilElec + utilWater + utilNet + utilTrash + utilHeating + utilCooling;\n\n        function fmtUtil(val) {\n            const converted = toDisplay(val);\n            const formatted = Math.round(converted).toLocaleString();\n            return (\n                sym +\n                formatted +\n                ' \u003cspan class=\"currency-native\"\u003e(' +\n                nativeSym +\n                val.toLocaleString() +\n                \")\u003c/span\u003e\"\n            );\n        }\n\n        \n        const downPayment = price * (downPercent / 100);\n        const loanAmount = price - downPayment;\n        const monthlyRate = rate / 100 / 12;\n        const numPayments = 30 * 12;\n\n        const mortgage =\n            (loanAmount *\n                (monthlyRate * Math.pow(1 + monthlyRate, numPayments))) /\n            (Math.pow(1 + monthlyRate, numPayments) - 1);\n        const tax = (price * (taxRate / 100)) / 12;\n        const insurance = (price * 0.0035) / 12;\n        const totalMonthly = mortgage + tax + insurance + hoa;\n\n        const totalMortgage = mortgage * numPayments;\n        const totalTax = tax * numPayments;\n        const totalInsurance = insurance * numPayments;\n        const totalHoa = hoa * numPayments;\n        const totalCost =\n            totalMortgage + totalTax + totalInsurance + totalHoa + downPayment;\n\n        \n        const dPrice = toDisplay(price);\n        const dDownPayment = toDisplay(downPayment);\n        const dMortgage = toDisplay(mortgage);\n        const dTax = toDisplay(tax);\n        const dInsurance = toDisplay(insurance);\n        const dTotalMonthly = toDisplay(totalMonthly);\n        const dTotalMortgage = toDisplay(totalMortgage);\n        const dTotalTax = toDisplay(totalTax);\n        const dTotalInsurance = toDisplay(totalInsurance);\n        const dTotalHoa = toDisplay(totalHoa);\n        const dTotalCost = toDisplay(totalCost);\n        const dTotalWithUtils = toDisplay(totalMonthly + totalUtilities);\n\n        \n        document.getElementById(\"total-monthly\").textContent =\n            sym + Math.round(dTotalMonthly).toLocaleString();\n        document.getElementById(\"total-cost\").textContent =\n            sym + Math.round(dTotalCost).toLocaleString();\n\n        document.getElementById(\"val-mortgage\").textContent =\n            sym + Math.round(dTotalMortgage).toLocaleString();\n        document.getElementById(\"val-tax\").textContent =\n            sym + Math.round(dTotalTax).toLocaleString();\n        document.getElementById(\"val-insurance\").textContent =\n            sym + Math.round(dTotalInsurance).toLocaleString();\n        document.getElementById(\"val-hoa\").textContent =\n            sym + Math.round(dTotalHoa).toLocaleString();\n        document.getElementById(\"val-down\").textContent =\n            sym + Math.round(dDownPayment).toLocaleString();\n\n        const maxVal = Math.max(\n            dTotalMortgage,\n            dTotalTax,\n            dTotalInsurance,\n            dTotalHoa,\n            dDownPayment,\n        );\n        document.getElementById(\"bar-mortgage\").style.width =\n            (dTotalMortgage / maxVal) * 100 + \"%\";\n        document.getElementById(\"bar-tax\").style.width =\n            (dTotalTax / maxVal) * 100 + \"%\";\n        document.getElementById(\"bar-insurance\").style.width =\n            (dTotalInsurance / maxVal) * 100 + \"%\";\n        document.getElementById(\"bar-hoa\").style.width =\n            (dTotalHoa / maxVal) * 100 + \"%\";\n        document.getElementById(\"bar-down\").style.width =\n            (dDownPayment / maxVal) * 100 + \"%\";\n\n        const extra = dTotalCost - dPrice;\n        const extraPct = Math.round((extra / dPrice) * 100);\n\n        document.getElementById(\"home-insight\").innerHTML =\n            '\u003cdiv class=\"summary-icon\"\u003e🏠\u003c/div\u003e\u003cp\u003e' +\n            homeCalcI18n.insight30yr\n                .replace(\"%PRICE%\", sym + Math.round(dPrice).toLocaleString())\n                .replace(\n                    \"%TOTAL%\",\n                    sym + Math.round(dTotalCost).toLocaleString(),\n                )\n                .replace(\"%PCT%\", extraPct + \"%\") +\n            \"\u003c/p\u003e\";\n\n        \n        document.getElementById(\"monthly-home\").textContent =\n            sym + Math.round(dTotalMonthly).toLocaleString();\n        if (settings \u0026\u0026 displayCurrency !== nativeCurrency) {\n            document.getElementById(\"monthly-total\").innerHTML =\n                sym +\n                Math.round(dTotalWithUtils).toLocaleString() +\n                ' \u003cspan class=\"currency-native\"\u003e(' +\n                nativeSym +\n                Math.round(totalMonthly + totalUtilities).toLocaleString() +\n                \")\u003c/span\u003e\";\n        } else {\n            document.getElementById(\"monthly-total\").textContent =\n                sym + Math.round(dTotalWithUtils).toLocaleString();\n        }\n\n        document.getElementById(\"val-mo-mortgage\").textContent =\n            sym + Math.round(dMortgage).toLocaleString();\n        document.getElementById(\"val-mo-tax\").textContent =\n            sym + Math.round(dTax).toLocaleString();\n        document.getElementById(\"val-mo-insurance\").textContent =\n            sym + Math.round(dInsurance).toLocaleString();\n        document.getElementById(\"val-mo-hoa\").textContent =\n            sym + Math.round(toDisplay(hoa)).toLocaleString();\n        document.getElementById(\"val-mo-elec\").innerHTML = fmtUtil(utilElec);\n        document.getElementById(\"val-mo-water\").innerHTML = fmtUtil(utilWater);\n        document.getElementById(\"val-mo-net\").innerHTML = fmtUtil(utilNet);\n        document.getElementById(\"val-mo-trash\").innerHTML =\n            utilTrash \u003e 0 ? fmtUtil(utilTrash) : homeCalcI18n.included;\n        document.getElementById(\"val-mo-heating\").innerHTML =\n            fmtUtil(utilHeating);\n        document.getElementById(\"val-mo-cooling\").innerHTML =\n            fmtUtil(utilCooling);\n\n        const maxMo = Math.max(\n            dMortgage,\n            dTax,\n            dInsurance,\n            toDisplay(hoa),\n            toDisplay(utilElec),\n            toDisplay(utilWater),\n            toDisplay(utilNet),\n            toDisplay(utilTrash || 1),\n            toDisplay(utilHeating || 1),\n            toDisplay(utilCooling || 1),\n        );\n        document.getElementById(\"bar-mo-mortgage\").style.width =\n            (dMortgage / maxMo) * 100 + \"%\";\n        document.getElementById(\"bar-mo-tax\").style.width =\n            (dTax / maxMo) * 100 + \"%\";\n        document.getElementById(\"bar-mo-insurance\").style.width =\n            (dInsurance / maxMo) * 100 + \"%\";\n        document.getElementById(\"bar-mo-hoa\").style.width =\n            (toDisplay(hoa) / maxMo) * 100 + \"%\";\n        document.getElementById(\"bar-mo-elec\").style.width =\n            (toDisplay(utilElec) / maxMo) * 100 + \"%\";\n        document.getElementById(\"bar-mo-water\").style.width =\n            (toDisplay(utilWater) / maxMo) * 100 + \"%\";\n        document.getElementById(\"bar-mo-net\").style.width =\n            (toDisplay(utilNet) / maxMo) * 100 + \"%\";\n        document.getElementById(\"bar-mo-trash\").style.width =\n            (toDisplay(utilTrash || 1) / maxMo) * 100 + \"%\";\n        document.getElementById(\"bar-mo-heating\").style.width =\n            (toDisplay(utilHeating || 1) / maxMo) * 100 + \"%\";\n        document.getElementById(\"bar-mo-cooling\").style.width =\n            (toDisplay(utilCooling || 1) / maxMo) * 100 + \"%\";\n\n        const utilPct = Math.round(\n            (totalUtilities / (totalMonthly + totalUtilities)) * 100,\n        );\n        document.getElementById(\"monthly-insight\").innerHTML =\n            '\u003cdiv class=\"summary-icon\"\u003e💡\u003c/div\u003e\u003cp\u003e' +\n            homeCalcI18n.insightMonthly\n                .replace(\"%UTILS%\", fmtUtil(totalUtilities))\n                .replace(\"%PCT%\", utilPct + \"%\") +\n            \"\u003c/p\u003e\";\n\n        const result = document.getElementById(\"home-result\");\n        result.style.display = \"block\";\n        result.scrollIntoView({ behavior: \"smooth\", block: \"nearest\" });\n    }\n\u003c/script\u003e\n\n\n\n\n\n\n\n\n\u003cdiv class=\"info-section\"\u003e\n  \u003cdiv class=\"info-section-header\"\u003e\n    \u003cdiv class=\"info-icon\"\u003e\n      \n      \u003csvg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"\u003e\u003cpath d=\"M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z\"/\u003e\u003cpolyline points=\"9 22 9 12 15 12 15 22\"/\u003e\u003c/svg\u003e\n      \n    \u003c/div\u003e\n    \u003ch3\u003e包含內容\u003c/h3\u003e\n  \u003c/div\u003e\n  \u003cdiv class=\"info-section-body\"\u003e\n    \u003cp\u003e我們的計算器考慮以下因素：\u003c/p\u003e\n\u003cul\u003e\n\u003cli\u003e\u003cstrong\u003e按揭貸款\u003c/strong\u003e — 基於您的首付和利率的本金+利息\u003c/li\u003e\n\u003cli\u003e\u003cstrong\u003e房產稅\u003c/strong\u003e — 按年計算，按月分攤\u003c/li\u003e\n\u003cli\u003e\u003cstrong\u003e房屋保險\u003c/strong\u003e — 按房屋價值的0.35%年估算\u003c/li\u003e\n\u003cli\u003e\u003cstrong\u003eHOA費用\u003c/strong\u003e — 月度協會會費\u003c/li\u003e\n\u003cli\u003e\u003cstrong\u003e維護費用\u003c/strong\u003e — 按房屋價值的1%年估算\u003c/li\u003e\n\u003cli\u003e\u003cstrong\u003e30年總成本\u003c/strong\u003e — 大多數購房者忽略的驚人真實數字\u003c/li\u003e\n\u003c/ul\u003e\n  \u003c/div\u003e\n\u003c/div\u003e\n\n\n\n\n\n\n\n\u003cdiv class=\"info-section\"\u003e\n  \u003cdiv class=\"info-section-header\"\u003e\n    \u003cdiv class=\"info-icon\"\u003e\n      \n      \u003csvg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"\u003e\u003cpath d=\"M9 18h6\"/\u003e\u003cpath d=\"M10 22h4\"/\u003e\u003cpath d=\"M12 2a7 7 0 0 0-7 7c0 2.38 1.19 4.47 3 5.74V17h8v-2.26c1.81-1.27 3-3.36 3-5.74a7 7 0 0 0-7-7z\"/\u003e\u003c/svg\u003e\n      \n    \u003c/div\u003e\n    \u003ch3\u003e爲什麼這很重要\u003c/h3\u003e\n  \u003c/div\u003e\n  \u003cdiv class=\"info-section-body\"\u003e\n    一套45萬美元的房子實際成本遠不止45萬美元。30年內，考慮到利息、稅費和保險，您實際需要支付接近\u003cstrong\u003e90萬美元\u003c/strong\u003e。在購買前瞭解真實數字。\n  \u003c/div\u003e\n\u003c/div\u003e\n\n\n\n\n\n\n\n\u003cdiv class=\"info-section\"\u003e\n  \u003cdiv class=\"info-section-header\"\u003e\n    \u003cdiv class=\"info-icon\"\u003e\n      \n      \u003csvg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"\u003e\u003cellipse cx=\"12\" cy=\"5\" rx=\"9\" ry=\"3\"/\u003e\u003cpath d=\"M21 12c0 1.66-4 3-9 3s-9-1.34-9-3\"/\u003e\u003cpath d=\"M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5\"/\u003e\u003c/svg\u003e\n      \n    \u003c/div\u003e\n    \u003ch3\u003e數據來源\u003c/h3\u003e\n  \u003c/div\u003e\n  \u003cdiv class=\"info-section-body\"\u003e\n    \u003cul\u003e\n\u003cli\u003e按揭計算：標準攤銷公式\u003c/li\u003e\n\u003cli\u003e房產稅率：稅務基金會\u003c/li\u003e\n\u003cli\u003e保險估算：行業平均值\u003c/li\u003e\n\u003c/ul\u003e\n\u003cp\u003e\u003cem\u003e最後更新：2026年6月28日\u003c/em\u003e\u003c/p\u003e\n  \u003c/div\u003e\n\u003c/div\u003e\n"}